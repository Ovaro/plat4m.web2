<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260618000200-1" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="fin_transaction_import_row" columnName="duplicate_strong_match"/>
            </not>
        </preConditions>
        <addColumn tableName="fin_transaction_import_row">
            <column name="duplicate_strong_match" type="boolean" defaultValueBoolean="false"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260618000200-2" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="fin_transaction_import_row" columnName="duplicate_rejected"/>
            </not>
        </preConditions>
        <addColumn tableName="fin_transaction_import_row">
            <column name="duplicate_rejected" type="boolean" defaultValueBoolean="false"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
